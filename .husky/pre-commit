#!/bin/sh
# .husky/pre-commit

echo "🔍 Running pre-commit checks..."

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
BACKEND_FILES=$(echo "$STAGED_FILES" | grep -E "^backend/.*\.(js|jsx)$" || true)
FRONTEND_FILES=$(echo "$STAGED_FILES" | grep -E "^frontend/.*\.(js|jsx)$" || true)

# Check if there are any files to lint
if [ -z "$STAGED_FILES" ]; then
  echo "✅ No files to check"
  exit 0
fi

# Run backend lint
if [ -n "$BACKEND_FILES" ]; then
  echo "📦 Linting backend files..."
  echo "$BACKEND_FILES" | while read file; do
    npx eslint "$file" --fix
  done
fi

# Run frontend lint
if [ -n "$FRONTEND_FILES" ]; then
  echo "📦 Linting frontend files..."
  echo "$FRONTEND_FILES" | while read file; do
    npx eslint "$file" --fix
  done
fi

# Re-stage fixed files
git diff --cached --name-only --diff-filter=ACM | while read file; do
  if git diff --quiet "$file" 2>/dev/null; then
    git add "$file"
  fi
done

echo "✅ Pre-commit checks complete"
