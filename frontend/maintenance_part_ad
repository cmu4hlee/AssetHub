router.post('/requests/:id/complete', authenticate, async (req, res) => {
  try {
    const { id } = req.params;
    const { repair_end_date, repair_cost, repair_content, parts_replaced, remark } = req.body;

    // 获取申请信息
    // 添加租户过滤验证
    const tenantFilter = addTenantFilter(req, 'mr');
    const [requests] = await db.execute(
      `SELECT mr.* FROM maintenance_requests mr WHERE mr.id = ? ${tenantFilter.whereClause}`,
      [id, ...tenantFilter.params]
    );

    if (requests.length === 0) {
      return res.status(404).json({ success: false, message: '故障维修申请不存在' });
    }

    const request = requests[0];

    if (request.status !== '维修中') {
      return res.status(400).json({ success: false, message: '只能完成维修中的申请' });
    }

    const connection = await db.getConnection();
    try {
      await connection.beginTransaction();

      // 更新申请状态（已验证租户）
      await connection.execute(
        `UPDATE maintenance_requests mr SET
          mr.status = ?,
          mr.repair_end_date = ?,
          mr.repair_cost = ?,
          mr.repair_content = ?,
          mr.parts_replaced = ?,
          mr.remark = ?,
          mr.updated_at = NOW()
        WHERE mr.id = ? ${tenantFilter.whereClause.replace('WHERE', 'AND')}`,
        [
          '已完成',
          repair_end_date || new Date().toISOString().split('T')[0],
          repair_cost || 0,
          repair_content || null,
          parts_replaced || null,
          remark || null,
          id,
          ...tenantFilter.params,
        ]
      );

      // 创建维护日志
      const createdBy = req.user.real_name || req.user.username || '系统管理员';
      const tenantId = getTenantId(req);
      await connection.execute(
        `INSERT INTO maintenance_logs (
          tenant_id, asset_code, asset_name, maintenance_type, maintenance_date,
          maintenance_person, maintenance_content, maintenance_cost, parts_replaced,
          status, remark, created_by
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
        [
          tenantId,
          request.asset_code,
          request.asset_name,
          '故障维修',
          repair_end_date || new Date().toISOString().split('T')[0],
          request.repair_person,
          repair_content || request.fault_description,
          repair_cost || 0,
          parts_replaced || null,
          '已完成',
          remark || null,
          createdBy,
        ]
      );

      // 检查资产当前状态（使用行锁防止并发问题）
      const [assets] = await connection.execute(
        'SELECT * FROM assets WHERE asset_code = ? FOR UPDATE',
        [request.asset_code]
      );

      if (assets.length === 0) {
        await connection.rollback();
        connection.release();
        return res.status(404).json({ success: false, message: '资产不存在' });
      }

      // 检查资产状态是否为"维修中"或"维修"
      const currentStatus = assets[0].status;
      if (currentStatus !== '维修中' && currentStatus !== '维修') {
        await connection.rollback();
        connection.release();
        return res.status(400).json({
          success: false,
          message: `资产当前状态为"${currentStatus}"，无法完成维修。资产必须处于"维修中"或"维修"状态才能完成维修。`,
        });
      }

      // 更新资产状态为在用
      await connection.execute(
        'UPDATE assets SET status = ?, updated_at = NOW() WHERE asset_code = ?',
        ['在用', request.asset_code]
      );

      await connection.commit();

      res.json({ success: true, message: '维修已完成，已创建维护日志' });
    } catch (error) {
      await connection.rollback();
      throw error;
    } finally {
      connection.release();
    }
  } catch (error) {
    console.error('完成维修失败:', error);
    res.status(500).json({ success: false, message: '完成维修失败', error: error.message });
  }
});

