    );

    if (requests.length === 0) {
      return res.status(404).json({ success: false, message: '故障维修申请不存在' });
    }

    if (!['已取消', '已拒绝'].includes(requests[0].status)) {
      return res.status(400).json({ success: false, message: '只能删除已取消或已拒绝的申请' });
