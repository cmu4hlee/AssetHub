# =============================================
# AssetHub 前端生产环境配置示例
# 复制此文件为 .env.production 并修改实际值
# 必须使用 https:// 协议，禁止使用 localhost 或 IP 地址
# =============================================

# 后端 API 地址（同源部署可不设置）
# 同源部署：前端和后端在同一个域名下（通过 Nginx 反代），不设置此项
# 跨域部署：设置为后端完整 URL，例如 https://api.your-domain.com
VITE_BACKEND_URL=

# API 基础路径（同源部署可不设置）
VITE_API_BASE_URL=/api

# 前端访问地址（用于飞书 OAuth 回调、分享链接等需要绝对 URL 的场景）
# 必填，必须使用公网可访问的域名
VITE_FRONTEND_URL=https://assethub.your-domain.com

# 备用前端 host 列表（用于 allowedHosts 校验，多个用逗号分隔）
VITE_FRONTEND_FALLBACK_HOSTS=assethub.your-domain.com,www.your-domain.com

# Vite 开发服务器允许的 host（仅开发服务器使用）
# true 表示允许所有 host（开发用），生产环境通过 Nginx 访问不需要此项
VITE_ALLOWED_HOSTS=true

# AI / Hermes 配置
VITE_HERMES_API_URL=
VITE_HERMES_MODEL=hermes2