// 获取推荐的维护计划模板
router.get('/templates/recommend', authenticate, async (req, res) => {
  try {
    const { asset_type, brand, model } = req.query;

    if (!asset_type) {
      return res.status(400).json({ success: false, message: '资产类型不能为空' });
    }

    let whereClause = 'WHERE status = ?';
    const params = ['启用'];

    // 按匹配程度排序：资产类型 + 品牌 + 型号 完全匹配 > 资产类型 + 品牌匹配 > 资产类型匹配
    if (asset_type) {
      whereClause += ' AND asset_type = ?';
      params.push(asset_type);
    }

    // 优先匹配品牌和型号
    const [templates] = await db.execute(
      `SELECT * FROM maintenance_templates
       ${whereClause}
       ORDER BY
         (CASE
           WHEN (brand = ? AND model = ?) THEN 3
           WHEN brand = ? THEN 2
           ELSE 1
         END) DESC
       LIMIT 10`,
      [...params, brand || '', model || '', brand || '']
    );

    // 解析JSON字段
    const parsedTemplates = templates.map(template => {
      if (template.maintenance_items) {
        try {
          template.maintenance_items = JSON.parse(template.maintenance_items);
        } catch (e) {
          template.maintenance_items = null;
        }
      }
      if (template.required_materials) {
        try {
          template.required_materials = JSON.parse(template.required_materials);
        } catch (e) {
          template.required_materials = null;
        }
      }
      return template;
    });

    res.json({ success: true, data: parsedTemplates });
  } catch (error) {
    console.error('获取推荐维护计划模板失败:', error);
