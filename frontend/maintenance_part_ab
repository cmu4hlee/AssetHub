    const params = [];

    // 添加租户过滤
    const tenantFilter = addTenantFilter(req, 'wo');
    whereClause += tenantFilter.whereClause;
    params.push(...tenantFilter.params);

    if (asset_code) {
      whereClause += ' AND wo.asset_code LIKE ?';
      params.push(`%${asset_code}%`);
    }
    if (status) {
      whereClause += ' AND wo.status = ?';
      params.push(status);
    }
    if (priority) {
      whereClause += ' AND wo.priority = ?';
      params.push(priority);
    }
    if (source_type) {
      whereClause += ' AND wo.source_type = ?';
      params.push(source_type);
    }
    if (keyword) {
      whereClause += ' AND (wo.work_order_no LIKE ? OR wo.title LIKE ? OR wo.asset_name LIKE ?)';
      const keywordParam = `%${keyword}%`;
