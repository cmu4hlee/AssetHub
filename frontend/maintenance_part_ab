// 完成预防性维护计划（自动更新下次维护日期）
router.post('/plans/:id/complete', authenticate, async (req, res) => {
  try {
    const { id } = req.params;
    const {
      maintenance_date,
      maintenance_person,
      maintenance_content,
      maintenance_cost,
      parts_replaced,
      remark,
      actual_hours,
      maintenance_result,
    } = req.body;

    // 获取计划信息（添加租户过滤验证）
    const tenantFilter = addTenantFilter(req, 'pmp');
    const [plans] = await db.execute(
      `SELECT pmp.* FROM preventive_maintenance_plans pmp WHERE pmp.id = ? ${tenantFilter.whereClause}`,
      [id, ...tenantFilter.params]
    );

    if (plans.length === 0) {
      return res.status(404).json({ success: false, message: '预防性维护计划不存在' });
    }

    const plan = plans[0];

    if (plan.status !== '启用') {
      return res.status(400).json({ success: false, message: '只能完成启用状态的计划' });
    }

    const connection = await db.getConnection();
    try {
      await connection.beginTransaction();

      // 创建维护日志
      const createdBy = req.user.real_name || req.user.username || '系统管理员';
      const tenantId = req.user.tenant_id;
      let maintenanceDateStr = maintenance_date || new Date().toISOString().split('T')[0];

      // 确保日期格式正确
      if (maintenanceDateStr instanceof Date) {
        maintenanceDateStr = maintenanceDateStr.toISOString().split('T')[0];
      } else if (typeof maintenanceDateStr === 'string' && maintenanceDateStr.includes('T')) {
        maintenanceDateStr = maintenanceDateStr.split('T')[0];
      }

      await connection.execute(
        `INSERT INTO maintenance_logs (
          tenant_id, asset_code, asset_name, maintenance_type, maintenance_date,
          maintenance_person, maintenance_content, maintenance_cost, parts_replaced,
          status, remark, created_by
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
        [
          tenantId,
          plan.asset_code,
          plan.asset_name,
          '预防性维护',
          maintenanceDateStr,
          maintenance_person || plan.responsible_person,
          maintenance_content || plan.maintenance_content,
          maintenance_cost || 0,
          parts_replaced || null,
          '已完成',
          remark || null,
          createdBy,
        ]
      );

      // 计算下次维护日期
      let maintenanceDate = maintenance_date || new Date().toISOString().split('T')[0];

      // 确保日期格式正确
      if (maintenanceDate instanceof Date) {
        maintenanceDate = maintenanceDate.toISOString().split('T')[0];
      } else if (typeof maintenanceDate === 'string' && maintenanceDate.includes('T')) {
        maintenanceDate = maintenanceDate.split('T')[0];
      }

      let nextDate = new Date(maintenanceDate);
      const cycleValue = parseInt(plan.cycle_value) || 1;
      const cycleType = plan.cycle_type || '按月';

      // 确保日期有效
      if (isNaN(nextDate.getTime())) {
        nextDate = new Date();
      }

      switch (cycleType) {
        case '按天':
          nextDate.setDate(nextDate.getDate() + cycleValue);
          break;
        case '按周':
          nextDate.setDate(nextDate.getDate() + cycleValue * 7);
          break;
        case '按月':
          nextDate.setMonth(nextDate.getMonth() + cycleValue);
          break;
        case '按季度':
          nextDate.setMonth(nextDate.getMonth() + cycleValue * 3);
          break;
        case '按年':
          nextDate.setFullYear(nextDate.getFullYear() + cycleValue);
          break;
        default:
          // 默认按月
          nextDate.setMonth(nextDate.getMonth() + cycleValue);
          break;
      }

      // 更新计划
      const lastMaintenanceDate = maintenanceDate;
      const nextMaintenanceDate = nextDate.toISOString().split('T')[0];

      await connection.execute(
        `UPDATE preventive_maintenance_plans SET
          last_maintenance_date = ?,
          next_maintenance_date = ?,
          updated_at = NOW()
        WHERE id = ?`,
        [lastMaintenanceDate, nextMaintenanceDate, id]
      );

      // 记录维护历史
      try {
        // 检查历史记录表是否存在
        const [historyTables] = await connection.execute(
          `SELECT TABLE_NAME FROM INFORMATION_SCHEMA.TABLES
           WHERE TABLE_SCHEMA = DATABASE()
           AND TABLE_NAME = 'maintenance_plan_history'`
        );

        if (historyTables.length > 0) {
          await connection.execute(
            `INSERT INTO maintenance_plan_history (
              plan_id, maintenance_date, maintenance_person, actual_hours,
              maintenance_result, maintenance_content, maintenance_cost, parts_replaced, remark
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`,
            [
              id,
              lastMaintenanceDate,
              maintenance_person || plan.responsible_person,
              actual_hours || null,
              maintenance_result || '正常',
              maintenance_content || plan.maintenance_content,
              maintenance_cost || null,
              parts_replaced || null,
              remark || null,
            ]
          );
        }
      } catch (historyError) {
        // 历史记录表不存在或插入失败，不影响主流程
        console.warn('记录维护历史失败:', historyError.message);
      }

      await connection.commit();

      res.json({ success: true, message: '预防性维护计划完成，已创建维护日志' });
    } catch (error) {
      await connection.rollback();
      throw error;
    } finally {
      connection.release();
    }
  } catch (error) {
    console.error('完成预防性维护计划失败:', error);
    console.error('错误详情:', {
      message: error.message,
      code: error.code,
      sqlState: error.sqlState,
      sqlMessage: error.sqlMessage,
      stack: error.stack,
    });
    res.status(500).json({
      success: false,
      message: '完成预防性维护计划失败',
      error: error.message,
      details:
        process.env.NODE_ENV === 'development'
          ? {
              code: error.code,
              sqlState: error.sqlState,
              sqlMessage: error.sqlMessage,
            }
          : undefined,
    });
  }
});

