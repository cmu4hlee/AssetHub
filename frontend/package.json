    "@zxing/library": "^0.21.3",
    "antd": "^6.1.4",
    "axios": "^1.15.2",
    "dayjs": "^1.11.19",
    "echarts": "^5.6.0",
    "howler": "^2.2.4",
    "jsbarcode": "^3.12.3",
    "jsqr": "^1.4.0",
    "picomatch": "^4.0.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.7.0",
