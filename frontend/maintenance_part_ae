    // 根据用户的管理科室过滤
    let departmentFilter = '';
    const departmentParams = [];

    if (selectedDepartmentId && !isNaN(parseInt(selectedDepartmentId))) {
      // 检查用户是否有权限查看该科室
      if (req.user.role === 'system_admin' || req.user.role === 'asset_admin') {
        // 系统管理员和资产管理员可以查看任意科室
        const [dept] = await db.execute(
          'SELECT department_name FROM departments WHERE id = ? AND tenant_id = ?',
          [selectedDepartmentId, getTenantId(req)]
        );
        if (dept.length > 0) {
          departmentFilter = ` AND EXISTS (
            SELECT 1 FROM assets a
            WHERE a.asset_code = ml.asset_code
            AND a.department = ?
          )`;
          departmentParams.push(dept[0].department_name);
        } else {
          // 科室不存在或不属于当前租户，返回空结果
          return res.json({ success: true, data: {} });
        }
      } else if (req.user.role === 'department_admin') {
        // 部门管理员只能查看自己管理的科室
        if (
          req.user.managed_departments &&
          req.user.managed_departments.includes(parseInt(selectedDepartmentId))
        ) {
          const [dept] = await db.execute(
            'SELECT department_name FROM departments WHERE id = ? AND tenant_id = ?',
            [selectedDepartmentId, getTenantId(req)]
          );
          if (dept.length > 0) {
            departmentFilter = ` AND EXISTS (
              SELECT 1 FROM assets a
              WHERE a.asset_code = ml.asset_code
              AND a.department = ?
            )`;
            departmentParams.push(dept[0].department_name);
          } else {
            // 科室不存在或不属于当前租户，返回空结果
            return res.json({ success: true, data: {} });
          }
        } else {
          // 没有权限查看该科室，返回空结果
          return res.json({ success: true, data: {} });
        }
      } else {
        // 普通用户没有权限查看指定科室，返回空结果
        return res.json({ success: true, data: {} });
