          const hasChinese = /[\u4e00-\u9fa5]/.test(file.originalname);
          console.log(`[附件上传] multer originalname 是否包含中文: ${hasChinese}`);

          // 如果文件名不包含中文，尝试修复编码（UTF-8 字节被错误解释为 Latin1）
          if (!hasChinese) {
            console.log('[附件上传] 检测到文件名可能乱码，开始修复...');
            try {
              // 将乱码字符串视为 Latin1 字节，然后用 UTF-8 解码
              const latin1Buffer = Buffer.from(file.originalname, 'latin1');
              const utf8Decoded = latin1Buffer.toString('utf8');
              console.log(`[附件上传] UTF-8 解码结果: ${utf8Decoded}`);

              // 检查解码结果是否包含有效的中文字符
              const chineseMatch = utf8Decoded.match(/[\u4e00-\u9fa5]+/g);
              if (chineseMatch && chineseMatch.length > 0) {
                // 检查替换字符比例
                const replacementCount = (utf8Decoded.match(/\uFFFD/g) || []).length;
                const replacementRatio = replacementCount / utf8Decoded.length;

                if (replacementRatio < 0.3) {
                  fileName = utf8Decoded;
                  console.log(`[附件上传] ✅ UTF-8 解码成功: ${fileName}`);
                } else {
                  console.log(
                    `[附件上传] UTF-8 解码结果质量不好（替换字符比例: ${replacementRatio.toFixed(2)}）`
                  );
                }
              }

              // 如果 UTF-8 解码失败，尝试 Windows 中文编码
              if (!/[\u4e00-\u9fa5]/.test(fileName)) {
                const encodings = ['gbk', 'gb2312', 'gb18030'];
                for (const encoding of encodings) {
                  try {
                    const decoded = iconv.decode(latin1Buffer, encoding);
                    if (/[\u4e00-\u9fa5]/.test(decoded)) {
                      fileName = decoded;
                      console.log(`[附件上传] ✅ 使用 ${encoding} 编码成功: ${fileName}`);
                      break;
                    }
                  } catch (e) {
                    // 继续尝试下一个编码
                  }
                }
              }
            } catch (e) {
              console.error('[附件上传] 编码修复失败:', e);
            }
          }
        }
      }

      // 最终验证
      if (!fileName) {
        fileName = file.originalname; // 如果所有方法都失败，使用原始值
        console.warn(`[附件上传] ⚠️ 所有文件名解析方法都失败，使用原始值: ${fileName}`);
      }

      console.log(`[附件上传] 最终文件名: ${fileName}`);

      const uploadedBy = req.user.real_name || req.user.username || '系统管理员';
      // 使用相对路径，前端会根据需要构建完整URL
      const filePath = `/uploads/maintenance-attachments/${file.filename}`;

      // 构建完整的访问URL（用于前端直接显示）
      const fileUrl = `${req.protocol}://${req.get('host')}${filePath}`;

      console.log(`[附件上传] 准备插入数据库，文件名: ${fileName}`);
      const [result] = await db.execute(
        `INSERT INTO maintenance_log_attachments
       (maintenance_log_id, file_name, file_path, file_type, file_size, uploaded_by, description)
       VALUES (?, ?, ?, ?, ?, ?, ?)`,
        [id, fileName, filePath, file.mimetype, file.size, uploadedBy, null]
      );
      console.log(`[附件上传] ✅ 数据库插入成功，附件ID: ${result.insertId}`);

      res.json({
        success: true,
        message: '附件上传成功',
        data: {
          id: result.insertId,
          file_name: fileName, // 使用处理后的文件名
          file_path: filePath,
          file_url: fileUrl,
          file_type: file.mimetype,
          file_size: file.size,
          uploaded_by: uploadedBy,
          upload_date: new Date().toISOString(),
        },
      });
    } catch (error) {
      console.error('[附件上传] 上传失败:', error);
      console.error('[附件上传] 错误堆栈:', error.stack);
      // 如果是文件类型错误，返回更友好的错误信息
      if (error.message && error.message.includes('不支持的文件类型')) {
        return res.status(400).json({ success: false, message: error.message });
      }
      // 如果是文件大小超限
      if (error.code === 'LIMIT_FILE_SIZE') {
        return res.status(400).json({ success: false, message: '文件大小超过限制（最大50MB）' });
      }
      res.status(500).json({ success: false, message: '上传附件失败', error: error.message });
    }
  }
);

