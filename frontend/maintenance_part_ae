// 下载维护日志附件
router.get('/logs/:logId/attachments/:attachmentId/download', authenticate, async (req, res) => {
  try {
    const { logId, attachmentId } = req.params;
    const [attachments] = await db.execute(
      'SELECT * FROM maintenance_log_attachments WHERE id = ? AND maintenance_log_id = ?',
      [attachmentId, logId]
    );

    if (attachments.length === 0) {
      return res.status(404).json({ success: false, message: '附件不存在' });
    }

    const attachment = attachments[0];
    const filePath = path.join(__dirname, '..', attachment.file_path);

    if (!fs.existsSync(filePath)) {
      return res.status(404).json({ success: false, message: '文件不存在' });
    }

    // 设置下载响应头（使用 RFC 5987 标准，支持中文文件名）
    const fileName = attachment.file_name;
    // ASCII 文件名（用于兼容性）
    const asciiFileName = Buffer.from(fileName, 'utf8').toString('latin1');
    // UTF-8 编码的文件名（RFC 5987）
    const encodedFileName = encodeURIComponent(fileName);
    res.setHeader(
      'Content-Disposition',
      `attachment; filename="${asciiFileName}"; filename*=UTF-8''${encodedFileName}`
    );
    res.download(filePath, fileName);
  } catch (error) {
    console.error('下载附件失败:', error);
    res.status(500).json({ success: false, message: '下载附件失败', error: error.message });
  }
});

