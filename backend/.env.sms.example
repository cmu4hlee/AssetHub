# 短信验证码服务配置

# 服务提供商: aliyun | tencent
SMS_PROVIDER=aliyun

# 阿里云配置
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=您的签名名称
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx

# 腾讯云配置
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_SMS_APP_ID=your_app_id
TENCENT_SMS_SIGN_NAME=您的签名名称
TENCENT_SMS_TEMPLATE_ID=1234567

# 验证码配置
SMS_CODE_EXPIRE=300
SMS_MAX_ATTEMPTS_PER_PHONE=5