# ============================================================
# MiniMax LLM 客户端
# 用途：
#   1. 采购与招标模块的 AI 辅助审批
#   2. 计量报告图像识别（多模态模型）
# 把本文件另存为 .env 或通过部署平台注入以下环境变量
# ============================================================

# === 端点 ===
# 国内端点（默认）
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# 海外端点（如选了 Global 改为）
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# API 路径（API 名 anthropic-messages,默认 messages,不要改）
MINIMAX_MESSAGES_PATH=messages

# === 认证（二选一） ===

# 方案 A：API Key 直连（拿到 key 后直接填这里）
# 控制台: https://platform.minimaxi.com → Coding Plan → API Keys
MINIMAX_API_KEY=

# 方案 B：OAuth Bearer Token（推荐，企业账号用 OAuth Portal）
# 终端交互认证拿到的 access_token，参考 OAuth_README.md
MINIMAX_ACCESS_TOKEN=

# === 超时（毫秒） ===
MINIMAX_TIMEOUT_MS=25000

# ============================================================
# 计量报告图像识别配置（使用 MiniMax 多模态模型）
# ============================================================

# 是否启用 MiniMax 图像识别（true=使用 MiniMax, false=使用本地 LM Studio）
MINIMAX_ENABLED=true

# 图像识别使用的模型（必须支持多模态的模型）
# 推荐: MiniMax-M3（支持图像理解）, MiniMax-M2.7
MINIMAX_MODEL=MiniMax-M3

# MiniMax API 基础地址（图像识别专用）
MINIMAX_API_BASE_URL=https://api.minimax.io

# 图像识别请求超时（毫秒）
MINIMAX_TIMEOUT=180000

# ============================================================
# 安全提示：
# 1. **不要**把含 key 的 .env 提交进 git（务必把 .env 加入 .gitignore）
# 2. **不要**在聊天/工单/截图里贴 key
# 3. 推荐把 key 放在部署平台的 Secret 管理（K8s Secret / Vault / SSM）
# ============================================================