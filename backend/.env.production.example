# =============================================
# AssetHub 后端生产环境配置示例
# 复制此文件为 .env 并修改实际值
# =============================================

# =========================
# 环境标识（必填）
# =========================
NODE_ENV=production

# =========================
# 服务器配置
# =========================
PORT=5183
SERVER_HOST=0.0.0.0

# =========================
# 前端配置（生产环境必填）
# 用于：飞书卡片链接、分享链接、邮件链接、附件 URL 等
# 必须使用公网可访问的 URL（不要使用 localhost）
# =========================
FRONTEND_URL=https://assethub.your-domain.com
FRONTEND_DOMAIN=assethub.your-domain.com
FRONTEND_PORT=443

# 后端公网 URL（用于附件直链，独立附件 CDN 时可与 FRONTEND_URL 不同）
# 同源部署时可不设置
PUBLIC_BASE_URL=https://api.your-domain.com

# =========================
# 安全配置（必填，强随机密钥）
# =========================
JWT_SECRET=please-replace-with-a-strong-random-secret-32chars-min
JWT_EXPIRES_IN=86400
JWT_REFRESH_EXPIRES_IN=604800
IOT_TOKEN_PEPPER=please-replace-with-another-strong-random-secret
IOT_LOCATION_INGEST_TOKEN=
IOT_ZONE_INGEST_TOKEN=
IOT_DEVICE_INGEST_TOKEN=

# =========================
# 数据库配置（生产环境必填）
# =========================
DB_HOST=mysql.your-domain.com
DB_PORT=3306
DB_USER=assethub
DB_PASSWORD=your_secure_db_password
DB_NAME=zcgl

# 从库（可选，未配置则与主库相同）
DB_READ_WRITE_SPLIT=false
DB_SLAVE_HOST=
DB_SLAVE_PORT=
DB_SLAVE_USER=
DB_SLAVE_PASSWORD=
DB_SLAVE_NAME=

# =========================
# Redis（可选）
# =========================
REDIS_HOST=redis.your-domain.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_ENABLED=false

# =========================
# 日志配置（生产建议启用文件日志）
# =========================
LOG_LEVEL=info
LOG_DIR=/var/log/assethub
ENABLE_FILE_LOG=true
ENABLE_CONSOLE_LOG=true
MAX_LOG_FILE_SIZE=10485760
MAX_LOG_FILES=30

# =========================
# 文件上传配置
# =========================
UPLOAD_DIR=/data/assethub/uploads
MAX_FILE_SIZE=10485760

# =========================
# CORS 配置（生产环境必须配置）
# 多个来源使用逗号分隔，必须使用 https:// 协议
# 同源部署时可以不设置（使用 FRONTEND_URL 兜底）
# 跨域部署时必须显式列出所有允许的前端域名
# =========================
CORS_ORIGIN=https://assethub.your-domain.com,https://admin.your-domain.com
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# =========================
# 网络与代理配置
# 如果使用 Nginx / SLB 反向代理，必须设置 TRUST_PROXY=true
# =========================
TRUST_PROXY=true
TRUST_PROXY_IPS=10.0.0.0/8,192.168.0.0/16

# IP 白名单（可选，仅允许特定 IP 访问）
ALLOWED_IPS=
ALLOWED_DOMAINS=
ENABLE_IP_WHITELIST=false
ENABLE_DOMAIN_WHITELIST=false

# =========================
# HTTPS 配置（建议启用）
# =========================
HTTPS=true
SSL_CERT=/etc/ssl/certs/assethub.crt
SSL_KEY=/etc/ssl/private/assethub.key

# =========================
# 飞书集成（生产环境配置）
# =========================
FEISHU_NOTIFICATION_ENABLED=true
FEISHU_HOST=https://open.feishu.cn

# =========================
# AI Provider（按需配置）
# =========================
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=claude-3-opus-20240229

# Hermes 本地 AI 网关（必须配置为可访问的地址）
VITE_HERMES_API_URL=

# =========================
# API 限流配置
# =========================
API_LIMIT_WINDOW_MS=900000
API_LIMIT_MAX=5000

# =========================
# 备份配置
# =========================
BACKUP_DIR=/data/assethub/backups
AUTO_BACKUP_INTERVAL=24
MAX_BACKUP_FILES=30
COMPRESS_BACKUP=true

# =========================
# 文件安全配置
# =========================
ALLOWED_MIME_TYPES=
ENABLE_MIME_TYPE_CHECK=true

# =========================
# 系统管理员配置
# =========================
CONFIG_BOOT_LOG_ENABLED=false
SYSTEM_ADMIN_ALLOWED_SCOPES=*