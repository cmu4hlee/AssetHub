// ============================================
// 启动服务器
// ============================================
const PORT = config.server.port;
const HOST = config.server.host;
let server;

// 聊天室服务已删除

// 服务器启动成功后的回调函数
const onServerStart = () => {
  console.log(`✅ 服务器运行在端口 ${PORT}`);
  console.log(`📡 健康检查: http://${HOST === '0.0.0.0' ? 'localhost' : HOST}:${PORT}/api/health`);
  console.log(`⏰ 启动时间: ${new Date().toISOString()}`);

  // 启动异步任务队列
  if (defaultQueue) {
    defaultQueue.start(5).catch(err => {
      console.error('⚠️ 异步任务队列启动失败:', err.message);
    });
  }

  // 运行缓存预热
  try {
    const { spawn } = require('child_process');
    const warmupProcess = spawn('node', ['scripts/warmup-cache.js'], {
      cwd: __dirname,
      detached: true,
      stdio: 'ignore',
    });
    warmupProcess.unref();
    console.log('✅ 缓存预热任务已启动');
  } catch (error) {
    console.warn('⚠️ 缓存预热启动失败:', error.message);
  }

  // WebSocket服务已删除
};

// 检查是否启用HTTPS
if (config.server.https && config.server.sslCert && config.server.sslKey) {
  // 启用HTTPS
  const https = require('https');
  const fs = require('fs');

  try {
    // 读取SSL证书和私钥
    const sslOptions = {
      cert: fs.readFileSync(config.server.sslCert),
      key: fs.readFileSync(config.server.sslKey),
    };

    // 创建HTTPS服务器
    server = https.createServer(sslOptions, app);

    // Socket.IO已删除

    // 监听HTTPS端口
    server.listen(PORT, HOST, () => {
      console.log('✅ HTTPS服务器已启动');
      onServerStart();
    });
  } catch (error) {
    console.error('❌ HTTPS服务器启动失败:', error.message);
    console.error('❌ 将回退到HTTP模式');

    // 回退到HTTP模式
    server = app.listen(PORT, HOST, () => {
      onServerStart();
    });
  }
} else {
  // 继续使用HTTP模式
  server = app.listen(PORT, HOST, () => {
    onServerStart();
  });

  // Socket.IO已删除
}

// ============================================
// 优雅关闭机制
const gracefulShutdown = signal => {
  console.log(`\n收到 ${signal} 信号，开始优雅关闭...`);

  server.close(() => {
    console.log('✅ HTTP 服务器已关闭');

    // 关闭数据库连接池
    if (db && typeof db.end === 'function') {
      try {
        db.end()
          .then(() => {
            console.log('✅ 数据库连接池已关闭');
            console.log('✅ 服务器已完全关闭');
            process.exit(0);
          })
          .catch(err => {
            console.error('❌ 关闭数据库连接池时出错:', err);
            console.log('✅ 服务器已完全关闭');
            process.exit(0);
          });
      } catch (error) {
        console.error('❌ 关闭数据库连接池时发生异常:', error);
        console.log('✅ 服务器已完全关闭');
        process.exit(0);
      }
    } else {
      console.log('✅ 数据库连接池未初始化，跳过关闭');
      console.log('✅ 服务器已完全关闭');
      process.exit(0);
    }
  });

  // 如果 10 秒内无法正常关闭，强制退出
  setTimeout(() => {
    console.error('❌ 强制退出进程');
    process.exit(1);
  }, 10000);
};

// 监听关闭信号
process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT', () => gracefulShutdown('SIGINT'));

// 处理服务器错误
server.on('error', error => {
  if (error.code === 'EADDRINUSE') {
    console.error(`❌ 端口 ${PORT} 已被占用`);
  } else {
    console.error('❌ 服务器错误:', error);
  }
  process.exit(1);
});
