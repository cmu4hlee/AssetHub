// ============================================
// 健康检查（包含数据库连接检查）
// ============================================
const HEALTH_DEP_TIMEOUT_MS = Number.parseInt(process.env.HEALTH_DEP_TIMEOUT_MS || '3000', 10);

const formatDependencyError = error => {
  if (!error) return 'unknown_error';
  const code = String(error.code || '').trim();
  const message = String(error.message || '').trim();
  return code || message || 'unknown_error';
};

const withTimeout = (promise, timeoutMs, timeoutCode) =>
  Promise.race([
    promise,
    new Promise((_, reject) => {
      const timeoutError = new Error(timeoutCode);
      timeoutError.code = timeoutCode;
      setTimeout(() => reject(timeoutError), timeoutMs);
    }),
  ]);

const checkDatabaseDependency = async (timeoutMs = HEALTH_DEP_TIMEOUT_MS) => {
  const startedAt = Date.now();
  let connection;

  try {
    connection = await withTimeout(db.getConnection(), timeoutMs, 'db_connect_timeout');
    await withTimeout(connection.ping(), timeoutMs, 'db_ping_timeout');

    return {
      name: 'database',
      status: 'up',
      required: true,
      latencyMs: Date.now() - startedAt,
    };
  } catch (error) {
    return {
      name: 'database',
      status: 'down',
      required: true,
      latencyMs: Date.now() - startedAt,
      error: formatDependencyError(error),
    };
  } finally {
    if (connection) {
      try {
        connection.release();
      } catch (releaseError) {
        // 忽略释放连接异常，避免影响健康检查结果
      }
    }
  }
};

const checkRedisDependency = async (timeoutMs = HEALTH_DEP_TIMEOUT_MS) => {
  const startedAt = Date.now();
  const redisEnabled = Boolean(config.redis?.enabled);

  if (!redisEnabled) {
    return {
      name: 'redis',
      status: 'disabled',
      required: false,
      latencyMs: 0,
      detail: 'redis_disabled_by_config',
    };
  }

  if (!redis) {
    return {
      name: 'redis',
      status: 'down',
      required: true,
      latencyMs: Date.now() - startedAt,
      error: 'redis_service_not_initialized',
    };
  }

  try {
    if (redis.isConnected && redis.client && typeof redis.client.ping === 'function') {
      await withTimeout(redis.client.ping(), timeoutMs, 'redis_ping_timeout');
      return {
        name: 'redis',
        status: 'up',
        required: true,
        latencyMs: Date.now() - startedAt,
      };
    }

    if (redis.isConnected) {
      return {
        name: 'redis',
        status: 'up',
        required: true,
        latencyMs: Date.now() - startedAt,
      };
    }

    return {
      name: 'redis',
      status: 'down',
      required: true,
      latencyMs: Date.now() - startedAt,
      error: redis.isMemoryCache ? 'redis_fallback_memory_cache' : 'redis_not_connected',
    };
  } catch (error) {
    return {
      name: 'redis',
      status: 'down',
      required: true,
      latencyMs: Date.now() - startedAt,
      error: formatDependencyError(error),
    };
  }
};

const collectDependencyHealth = async (timeoutMs = HEALTH_DEP_TIMEOUT_MS) => {
  const [database, redisDependency] = await Promise.all([
    checkDatabaseDependency(timeoutMs),
    checkRedisDependency(timeoutMs),
  ]);

  const dependencies = {
    database,
    redis: redisDependency,
  };

  const failedRequiredDependencies = Object.values(dependencies).filter(
    dependency => dependency.required && dependency.status !== 'up',
  );

  return {
    status: failedRequiredDependencies.length === 0 ? 'ok' : 'error',
    dependencies,
    failedRequiredDependencies,
    timeoutMs,
  };
};

/**
 * @swagger
 * /api/health:
 *   get:
 *     tags:
 *       - 系统
 *     summary: 轻量健康检查
 *     description: 快速返回服务存活状态（不阻塞等待外部依赖）
 *     security: []
 *     responses:
 *       200:
 *         description: 服务进程存活
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 status:
 *                   type: string
 *                   example: ok
 *                 message:
 *                   type: string
 *                   example: 资产管理服务运行正常
 *                 timestamp:
 *                   type: string
 *                   format: date-time
 */
/**
 * @swagger
 * /api/health/dependencies:
 *   get:
 *     tags:
 *       - 系统
 *     summary: 依赖健康检查
 *     description: 检查数据库和Redis等关键依赖，供运维告警与Readiness探针使用
 *     security: []
 *     responses:
 *       200:
 *         description: 依赖正常
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 status:
 *                   type: string
 *                   example: ok
 *                 message:
 *                   type: string
 *                   example: 关键依赖运行正常
 *                 timeoutMs:
 *                   type: integer
 *                   example: 3000
 *                 dependencies:
 *                   type: object
 *                 timestamp:
 *                   type: string
 *                   format: date-time
 *       503:
 *         description: 关键依赖异常
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 status:
 *                   type: string
 *                   example: error
 *                 message:
 *                   type: string
 *                   example: 存在异常依赖，请关注告警
 *                 failedDependencies:
 *                   type: array
 *                   items:
 *                     type: string
 *                 dependencies:
 *                   type: object
 *                 timestamp:
 *                   type: string
 *                   format: date-time
 */
// 轻量健康检查：先立即返回 200，避免前端/代理因等待 DB 而一直转圈；后台再检查依赖并记录日志
app.get('/api/health', (req, res) => {
  res.json({
    status: 'ok',
    message: '资产管理服务运行正常',
    timestamp: new Date().toISOString(),
  });

  // 后台检查依赖（不阻塞响应），仅用于日志
  setImmediate(async () => {
    try {
      const dependencyHealth = await collectDependencyHealth();
      if (dependencyHealth.status === 'ok') {
        console.log('✅ 健康检查后台: 关键依赖正常');
      } else {
        const failedDependencyNames = dependencyHealth.failedRequiredDependencies.map(
          dependency => dependency.name,
        );
        console.warn(
          `⚠️ 健康检查后台: 关键依赖异常(${failedDependencyNames.join(', ') || 'unknown'})`,
        );
      }
    } catch (error) {
      console.error('健康检查后台: 依赖检测异常', error.message);
    }
  });
});

// 真实依赖状态检查（供运维告警/Readiness使用）
app.get('/api/health/dependencies', async (req, res) => {
  try {
    const dependencyHealth = await collectDependencyHealth();
    const failedDependencies = dependencyHealth.failedRequiredDependencies.map(
      dependency => dependency.name,
    );
    const httpStatus = dependencyHealth.status === 'ok' ? 200 : 503;

    return res.status(httpStatus).json({
      status: dependencyHealth.status,
      message:
        dependencyHealth.status === 'ok' ? '关键依赖运行正常' : '存在异常依赖，请关注告警',
      timeoutMs: dependencyHealth.timeoutMs,
      failedDependencies,
      dependencies: dependencyHealth.dependencies,
      timestamp: new Date().toISOString(),
    });
  } catch (error) {
    return res.status(503).json({
      status: 'error',
      message: '依赖健康检查失败',
      error: error.message,
      timestamp: new Date().toISOString(),
    });
  }
});

