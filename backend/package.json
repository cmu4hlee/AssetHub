    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2"
  },
