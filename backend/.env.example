# =============================================
# AssetHub 后端配置示例
# 复制此文件为 .env 并填写实际值
# =============================================

# =========================
# 基础运行配置
# =========================
NODE_ENV=development
PORT=5183
SERVER_HOST=0.0.0.0

# =========================
# 前端配置
# =========================
FRONTEND_URL=http://localhost:13579
FRONTEND_DOMAIN=localhost
FRONTEND_PORT=13579

# =========================
# 安全配置（必填）
# =========================
# 必须替换为随机强密钥（建议 32+ 字符）
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=86400
JWT_REFRESH_EXPIRES_IN=604800
IOT_TOKEN_PEPPER=replace-with-a-different-strong-random-secret
IOT_LOCATION_INGEST_TOKEN=
IOT_ZONE_INGEST_TOKEN=
IOT_DEVICE_INGEST_TOKEN=

# =========================
# 数据库配置
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=zcgl

# =========================
# Redis（可选）
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=false

# =========================
# 日志配置
# =========================
LOG_LEVEL=debug
LOG_DIR=./logs
ENABLE_FILE_LOG=false
ENABLE_CONSOLE_LOG=true
MAX_LOG_FILE_SIZE=10485760
MAX_LOG_FILES=10

# =========================
# 文件上传配置
# =========================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# =========================
# 备份配置
# =========================
BACKUP_DIR=./backups
AUTO_BACKUP_INTERVAL=0
MAX_BACKUP_FILES=30

# =========================
# CORS配置
# =========================
CORS_ORIGIN=http://localhost:3000,http://localhost:4000,http://localhost:13579
CORS_CREDENTIALS=true

# =========================
# 网络配置
# =========================
ALLOWED_IPS=127.0.0.1,::1
ALLOWED_DOMAINS=localhost,127.0.0.1
ENABLE_IP_WHITELIST=false
ENABLE_DOMAIN_WHITELIST=false
TRUST_PROXY=true

# =========================
# API 限流配置
# =========================
API_LIMIT_WINDOW_MS=900000
API_LIMIT_MAX=5000

# =========================
# AI Provider（按需配置）
# 未配置则对应能力会被禁用
# =========================
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=claude-3-opus-20240229

CHAT2DB_AI_API_KEY=
CHAT2DB_AI_API_HOST=https://api.openai.com/v1
CHAT2DB_AI_MODEL=gpt-4o-mini

# =========================
# Chat2DB 登录凭据（成对配置）
# =========================
CHAT2DB_USERNAME=
CHAT2DB_PASSWORD=

# =========================
# SQLBot 鉴权（二选一）
# 1) 直接使用 Open API Key
# 2) 同时提供用户名与密码
# =========================
SQLBOT_OPEN_API_KEY=
SQLBOT_OPEN_API_USERNAME=
SQLBOT_OPEN_API_PASSWORD=

# =========================
# OpenClaw Gateway（OpenAI 兼容）
# =========================
OPENCLAW_ENABLED=false
GATEWAY_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
GATEWAY_TIMEOUT=300000

# =========================
# Chat2DB 完整配置
# =========================
CHAT2DB_BASE_URL=http://127.0.0.1:10824
CHAT2DB_LOGIN_PATH=/api/oauth/login_a
CHAT2DB_CHAT_PATH=/api/ai/chat
CHAT2DB_DATASOURCE_LIST_PATH=/api/connection/datasource/list
CHAT2DB_DATASOURCE_ID=1
CHAT2DB_TIMEOUT=30000
CHAT2DB_SSE_TIMEOUT=120000
CHAT2DB_SESSION_TTL_MS=1800000

# =========================
# 数据库高级配置
# =========================
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT=10000
DB_IDLE_TIMEOUT=60000
DB_MAX_IDLE=10

# =========================
# 数据库读写分离（可选）
# =========================
DB_READ_WRITE_SPLIT=false
DB_USE_SLAVE_FOR_READS=false
DB_SLAVE_HOST=127.0.0.1
DB_SLAVE_PORT=3306
DB_SLAVE_USER=root
DB_SLAVE_PASSWORD=
DB_SLAVE_NAME=zcgl
DB_SLAVE_CONNECTION_LIMIT=10
DB_SLAVE_QUEUE_LIMIT=0
DB_SLAVE_CONNECT_TIMEOUT=10000
DB_SLAVE_IDLE_TIMEOUT=60000
DB_SLAVE_MAX_IDLE=10

# =========================
# HTTPS 配置（可选）
# =========================
HTTPS=false
SSL_CERT=
SSL_KEY=

# =========================
# 代理与 CORS 高级配置
# =========================
TRUST_PROXY_IPS=
CORS_MAX_AGE=86400

# =========================
# 文件安全配置
# =========================
ALLOWED_MIME_TYPES=
ENABLE_MIME_TYPE_CHECK=true

# =========================
# 备份压缩
# =========================
COMPRESS_BACKUP=true

# =========================
# StatsD 监控（可选）
# =========================
STATSD_ENABLED=false
STATSD_HOST=127.0.0.1
STATSD_PORT=8125
STATSD_PREFIX=assethub

# =========================
# Redis 高级配置
# =========================
REDIS_CONNECT_TIMEOUT=10000
REDIS_MAX_CONNECTIONS=10
REDIS_DEFAULT_EXPIRE=3600

# =========================
# 系统管理员配置
# =========================
CONFIG_BOOT_LOG_ENABLED=true
SYSTEM_ADMIN_ALLOWED_SCOPES=*

# =========================
# SQLBot 高级配置
# =========================
SQLBOT_OPEN_API_BASE_URL=http://localhost:8000
SQLBOT_OPEN_API_PREFIX=/api/v1/open
SQLBOT_OPEN_DEFAULT_DATASOURCE_ID=1
SQLBOT_OPEN_CONNECT_TIMEOUT_MS=10000
SQLBOT_OPEN_READ_TIMEOUT_MS=30000
SQLBOT_OPEN_MAX_RETRIES=3
SQLBOT_OPEN_RETRY_BACKOFF_MS=1800

# =========================
# Chat2DB 高级配置
# =========================
CHAT2DB_DATASOURCE_ID=1
CHAT2DB_TIMEOUT=30000
CHAT2DB_SSE_TIMEOUT=120000
CHAT2DB_UID_PREFIX=assethub
CHAT2DB_SESSION_TTL_MS=1800000
CHAT2DB_PROXY_BASE_URL=http://127.0.0.1:18080
CHAT2DB_PROXY_HEALTH_PATH=/api/ai-assistant/chat2db/health
CHAT2DB_PROXY_STREAM_PATH=/api/ai-assistant/chat2db/chat/stream
CHAT2DB_PROXY_CHAT_PATH=/api/ai-assistant/chat2db/chat
CHAT2DB_AI_CONFIG_PATH=/api/config/system_config/ai
CHAT2DB_AI_SQL_SOURCE=OPENAI
CHAT2DB_AI_API_HOST=https://api.openai.com/v1
CHAT2DB_AI_MODEL=gpt-4o-mini
CHAT2DB_AI_STREAM=true
CHAT2DB_AI_CONFIG_TTL_MS=600000

# =========================
# 资产AI助手
# =========================
ASSET_ASSISTANT_BASE_URL=

# =========================
# Business Ops Assistant (Code Plan)
# =========================
CODE_PLAN_API_KEY=
CODE_PLAN_BASE_URL=https://api.minimaxi.com/anthropic
CODE_PLAN_MODEL=claude-3-opus-20240229

# =========================
# AI 追踪日志
# =========================
GATEWAY_AI_TRACE_LOG_ENABLED=false
