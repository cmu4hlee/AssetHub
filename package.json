{
  "name": "assethub",
  "version": "1.0.0",
  "description": "AssetHub Enterprise Asset Management System",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:fix": "npm run lint:backend:fix && npm run lint:frontend:fix",
    "lint:backend:fix": "cd backend && npm run lint:fix",
    "lint:frontend:fix": "cd frontend && npm run lint:fix",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm run test",
    "test:coverage": "npm run test:backend:coverage && npm run test:frontend:coverage",
    "test:backend:coverage": "cd backend && npm run test:coverage",
    "test:frontend:coverage": "cd frontend && npm run test:coverage",
    "format": "npm run format:backend && npm run format:frontend",
    "format:backend": "cd backend && npm run format",
    "format:frontend": "cd frontend && npm run format",
    "audit:docs": "cd backend && npm run audit:docs",
    "audit:routes": "cd backend && npm run audit:routes",
    "migrate": "cd backend && npm run migrate",
    "migrate:up": "cd backend && npm run migrate:up",
    "migrate:status": "cd backend && npm run migrate:status",
    "docker:build": "docker-compose build --no-cache",
    "docker:build:backend": "cd backend && docker build -t assetrob/backend:latest .",
    "docker:build:frontend": "cd frontend && docker build -t assetrob/frontend:latest .",
    "docker:up": "docker-compose up -d",
    "docker:up:build": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:backend": "docker-compose logs -f backend",
    "docker:logs:frontend": "docker-compose logs -f frontend",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v --rmi local",
    "docker:status": "docker-compose ps",
    "docker:rebuild": "npm run docker:down && npm run docker:build && npm run docker:up"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
